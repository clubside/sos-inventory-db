ts/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="workCenters" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="35"/><column index="2" value="69"/><column index="3" value="107"/><column index="4" value="63"/><column index="5" value="233"/><column index="6" value="97"/><column index="7" value="65"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="workOrders" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="35"/><column index="2" value="50"/><column index="3" value="69"/><column index="4" value="147"/><column index="5" value="144"/><column index="6" value="300"/><column index="7" value="276"/><column index="8" value="52"/><column index="9" value="76"/><column index="10" value="148"/><column index="11" value="183"/><column index="12" value="109"/><column index="13" value="300"/><column index="14" value="231"/><column index="15" value="300"/><column index="16" value="42"/><column index="17" value="44"/><column index="18" value="57"/><column index="19" value="87"/><column index="20" value="83"/><column index="21" value="35"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="workers" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="35"/><column index="2" value="69"/><column index="3" value="61"/><column index="4" value="63"/><column index="5" value="64"/><column index="6" value="76"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1">SELECT itemCategories.id, itemCategories.name, (SELECT COUNT(*) FROM items WHERE itemCategoryId = itemCategories.id) c FROM itemCategories ORDER BY c DESC</sql><sql name="SQL 2">SELECT id, name, vendor FROM items WHERE vendor IS NOT NULL</sql><sql name="part-lookup.sql" filename="V:/dev/wdmapp/db/part-lookup.sql">-- Reference to file &quot;V:/dev/wdmapp/db/part-lookup.sql&quot; (not supported by this version) --</sql><sql name="bin-lookup.sql" filename="V:/dev/wdmapp/db/bin-lookup.sql">-- Reference to file &quot;V:/dev/wdmapp/db/bin-lookup.sql&quot; (not supported by this version) --</sql><sql name="SQL 10">select * from bins where number like '%' || X'09' || '%'

select distinct number from bins where locationId = 3 and number like '%-%' order by number</sql><sql name="SQL 11">select
	bins.number, items.description, items.name, items.reorderPoint, items.maxStock - items.reorderPoint orderQuantity, 
	binItems.quantity shelfQty
from
	bins
	left join binItems on binItems.binId = bins.id
	left join items on items.id = binItems.itemId
where
	bins.locationId = 3
	and bins.number like 'slp14%'
order by
	bins.binNumberLead, bins.binNumberLeadNum, bins.binNumberContainer, bins.binNumberContainerSlot, bins.binNumberContainerExtra, items.name</sql><sql name="SQL 7">select id, description, number, (select count(*) from binItems where binId = bins.id) c from bins where locationId = 3 order by binNumberLead, binNumberLeadNum, binNumberContainer, binNumberContainerSlot, binNumberContainerExtra

select binItems.itemId, bins.number, items.description, vendors.name supplier, items.name partNumber, items.reorderPoint, items.maxStock - items.reorderPoint orderQuantity, binItems.quantity shelfQty, items.purchaseCost cost
from
	bins
	left join binItems on binItems.binId = bins.id
	left join items on items.id = binItems.itemId
	left join vendors on vendors.id = items.vendorId
where
	bins.number = 'S-1'
order by
	items.name
	
select distinct substr(number, 1, 3) leader from bins order by leader</sql><sql name="SQL 8">select bins.number, binItems.quantity
from bins inner join binItems on binItems.binId = bins.id
where bins.locationId = 3 and bins.number != 'S-1' and binItems.itemId = 3496</sql><current_tab id="7"/></tab_sql></sqlb_project>
